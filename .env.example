# Copy this file to .env.local and fill in the values from your Supabase project:
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key. Bypasses RLS — used by the subscribe action to insert into
# the `subscribers` table (which has no public-write policy). Never expose this
# to the browser; only import it from server actions / route handlers.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile — free bot/spam protection on the subscribe form.
# Create a (free) widget at https://dash.cloudflare.com/?to=/:account/turnstile
# and paste the two keys below. Until both are set the form still works and the
# check is skipped (no-op), so local dev needs nothing. Set both before launch.
#   - Site key is public (sent to the browser) → NEXT_PUBLIC_ prefix.
#   - Secret key is server-only → never expose it to the browser.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Resend — transactional + newsletter email provider (brief 04).
# Create an API key at https://resend.com/api-keys. Server-only — never expose
# to the browser. Until it is set, sendEmail() logs the message (including the
# confirm/unsubscribe link) to the server console instead of sending, so local
# dev works without a provider account. MUST be set before the first real send.
RESEND_API_KEY=your-resend-api-key

# From address for all outbound subscriber email. The domain must be verified in
# Resend (SPF + DKIM) or mail will be spam-filtered. Format: "Name <addr@domain>".
EMAIL_FROM=The Next Brick <news@thenextbrick.ai>

# Canonical public site origin, used to build absolute confirm/unsubscribe links
# in emails (they're opened from a mail client, not the site). No trailing slash.
# Falls back to the request Host header, then localhost, when unset.
NEXT_PUBLIC_SITE_URL=https://thenextbrick.ai
